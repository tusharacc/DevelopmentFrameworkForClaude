{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'r=$(git rev-parse --show-toplevel 2>/dev/null); h=\"$r/hooks/check-phase.sh\"; [ -f \"$h\" ] && bash \"$h\" || exit 0'"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'r=$(git rev-parse --show-toplevel 2>/dev/null); h=\"$r/hooks/check-bash-phase.sh\"; [ -f \"$h\" ] && bash \"$h\" || exit 0'"
          }
        ]
      }
    ]
  }
}
